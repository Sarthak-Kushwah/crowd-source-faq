# Backend environment variables
# Copy to .env and fill in values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:***@cluster0.z3cgb58.mongodb.net/?appName=Cluster0

# JWT secret — use a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_me

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Server port
PORT=6767

# Upstash Redis (optional — enables cross-instance semantic cache)
# Free tier: https://console.upstash.com → Create Redis Database → REST API
REDIS_URL=https://xxx.upstash.io
REDIS_TOKEN=***

# Sentry (optional — production error tracking)
# Create a project at https://sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Zoom OAuth (per-user) ────────────────────────────────────────────────────────
# Create a User-managed OAuth app at https://marketplace.zoom.us
# Required scopes: recording:read, meeting:read:admin
# Required events: recording.transcript_completed
# OAuth redirect URL (must match what's in Zoom App settings):
#   Development: http://localhost:6767/api/zoom/auth/callback
#   Production:  https://yaksha-faq-backend.vercel.app/api/zoom/auth/callback
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_REDIRECT_URI=http://localhost:6767/api/zoom/auth/callback
# Privacy: comma-separated regexes — matching meeting topics are skipped
ZOOM_TOPIC_BLACKLIST=

# ── MiniMax API Key (for Zoom transcript → FAQ extraction) ─────────────────────
# Get from https://platform.minimax.io — Token Plan → API Key
MINIMAX_API_KEY=your_minimax_api_key
